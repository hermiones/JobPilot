generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApplicationStatus {
  queued
  approved
  applied
  responded
  interview
  rejected
  offer
}

model User {
  id                     String   @id @default(cuid())
  email                  String   @unique
  passwordHash           String // bcrypt hash — see src/lib/auth/password.ts
  masterResume           String // free-text resume content used as the base for tailoring
  masterResumeFileName   String? // optional uploaded resume file name
  masterResumeFileData   String? // optional uploaded resume, base64-encoded
  coverLetterTemplates   String // JSON array of { tone: string, body: string }
  targetRoles            String // JSON array of strings
  targetLocations        String // JSON array of strings
  salaryFloor            Int? // in INR
  excludedCompanies      String // JSON array of strings
  dailyGoal              Int      @default(50)
  scheduleEnabled        Boolean  @default(false)
  scheduleTimes          String   @default("[]") // JSON array of IST "HH:MM" strings; auto-refresh runs at these times
  apiKeys                String   @default("[]") // JSON array of { provider, label, key } — bring-your-own AI provider keys
  preferredProvider      String   @default("gemini") // which apiKeys entry (by provider) to use for tailoring
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  applications Application[]
  matches      Match[]
}

// A discovered/verified public job board (Greenhouse token or Lever handle)
// that the aggregator pulls from. Populated by auto-discovery probing.
model Board {
  id           String   @id @default(cuid())
  source       String // greenhouse | lever
  slug         String // company token / handle
  label        String? // human-friendly company name
  active       Boolean  @default(true)
  lastJobCount Int      @default(0)
  lastCheckedAt DateTime @default(now())
  createdAt    DateTime @default(now())

  @@unique([source, slug])
}

model JobListing {
  id          String   @id @default(cuid())
  source      String // greenhouse | lever | remoteok | adzuna | manual
  externalId  String // id from the source system, used for de-duplication
  title       String
  company     String
  location    String?
  url         String
  description String
  postedDate  DateTime?
  salaryRange String?
  fetchedAt   DateTime @default(now())

  applications Application[]
  matches      Match[]

  @@unique([source, externalId])
  @@index([company, title])
}

model Application {
  id               String            @id @default(cuid())
  userId           String
  jobListingId     String
  status           ApplicationStatus @default(queued)
  resumeVersion    String? // tailored resume text snapshot used for this application
  coverLetterVersion String? // tailored cover letter text snapshot used for this application
  attachedResumeName String? // file name of a resume attached to this specific application
  attachedResumeData String? // attached resume, base64-encoded
  appliedAt        DateTime?
  lastUpdated      DateTime          @updatedAt
  notes            String?
  followUpDate     DateTime?
  createdAt        DateTime          @default(now())

  user       User       @relation(fields: [userId], references: [id])
  jobListing JobListing @relation(fields: [jobListingId], references: [id])

  @@unique([userId, jobListingId])
  @@index([userId, status])
}

model Match {
  id             String   @id @default(cuid())
  userId         String
  jobListingId   String
  relevanceScore Float
  reasons        String // JSON array of strings explaining the score
  createdAt      DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id])
  jobListing JobListing @relation(fields: [jobListingId], references: [id])

  @@unique([userId, jobListingId])
  @@index([userId, relevanceScore])
}
