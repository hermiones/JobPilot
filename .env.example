# Postgres connection string (e.g. Neon, Supabase, or Vercel Postgres)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
GEMINI_API_KEY="your-gemini-api-key-here"

# Random secret used to sign login session cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="replace-with-a-random-64-char-hex-string"

# Optional: protects /api/cron/run from public calls. Set this and configure
# your scheduler (e.g. Vercel Cron) to send `Authorization: Bearer <value>`.
CRON_SECRET=""
